<?xml version="1.0"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xsi="http://www.w3.org/2001/XMLSchema-instance" schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="Entities\MailboxTask" repository-class="Repositories\MailboxTask" table="mailbox_task">
    <id name="id" type="bigint">
      <generator strategy="AUTO"/>
    </id>
    <field name="type" type="string" length="32" nullable="false"/>
    <field name="username" type="string" length="255" nullable="false"/>
    <field name="status" type="string" length="32" nullable="false"/>
    <field name="priority" type="integer" nullable="false"/>
    <field name="created_at" type="datetime" nullable="false"/>
    <field name="started_at" type="datetime" nullable="true"/>
    <field name="finished_at" type="datetime" nullable="true"/>
    <field name="log" type="text" nullable="true"/>
    <field name="data" type="text" nullable="true"/>
    <many-to-one field="Domain" target-entity="Entities\Domain">
      <join-columns>
        <join-column name="Domain_id" referenced-column-name="id" nullable="true" on-delete="SET NULL"/>
      </join-columns>
    </many-to-one>
    <many-to-one field="RequestedBy" target-entity="Entities\Admin">
      <join-columns>
        <join-column name="Admin_id" referenced-column-name="id" nullable="true" on-delete="SET NULL"/>
      </join-columns>
    </many-to-one>
    <indexes>
      <index name="mailbox_task_status_idx" columns="status"/>
    </indexes>
  </entity>
</doctrine-mapping>
