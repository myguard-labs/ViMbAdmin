<div class="modal-header">
    <a href="#" class="close" data-dismiss="modal">&times;</a>
       <h3>Email Settings</h3>
</div>
<div class="modal-body" id="esbody">
    <p>Email settings for '<em>{$mailbox->getUsername()}</em>'.</p>

{if isset( $esError ) && $esError}
    <div class="alert alert-error">{$esError|escape}</div>
{/if}

    <form action="{genUrl controller='mailbox' action='email-settings' mid=$mailbox->getId()}/send/1"
          method="post" id="email_settings_form" name="email_settings_form" class="form-horizontal">

        <input type="hidden" name="csrf" value="{$csrfToken}" />

        <div style="position: fixed; z-index: 1;">
            <select name="type" id="type" class="required" title="Email">
{foreach $typeOptions as $optValue => $optLabel}
                <option value="{$optValue|escape}"{if $optValue == $selectedType} selected="selected"{/if}>{$optLabel|escape}</option>
{/foreach}
            </select>
        </div>

        <div class="control-group">
            <label class="control-label optional">&nbsp;</label>
            <div class="controls"></div>
        </div>

        <div id="other_email" {if $selectedType != 'other'}style="display: none"{/if}>
            <input type="text" name="email" id="email" size="32" class="required"
                   placeholder="email1@example.com,email2@example.com" value="{$emailValue|escape}" />
        </div>

    </form>
</div>

<div class="modal-footer" id="esfooter">
    <button id="modal_dialog_save" class="btn btn-primary">Send</button>
    <button id="modal_dialog_cancel" class="btn">Close</button>
</div>


<script type="text/javascript">
    $( 'document' ).ready( function() {

        $( "#type" ).on( 'change', function(){
            if( $( "#type" ).val() == "other" )
                $( '#other_email' ).slideDown( "slow" );
            else
                $( '#other_email' ).slideUp( "slow" );
        });

        $( '#modal_dialog_save' ).bind('click', function() {
            var Throb = tt_throbber( 32, 14, 1.8 ).appendTo( $( '#esfooter' ).get(0) ).start();

            $('#modal_dialog_save').attr('disabled', 'disabled' ).addClass( 'disabled' );
            $('#modal_dialog_cancel').attr('disabled', 'disabled' ).addClass( 'disabled' );

            $.ajax({
                url: "{genUrl controller='mailbox' action='email-settings' mid=$mailbox->getId()}/send/1",
                data: $( '#email_settings_form' ).serialize(),
                async: true,
                cache: false,
                type: 'POST',
                timeout: 10000,
                success: function(data) {
                    if( data == "ok" ) {
                        dialog.modal('hide');
                        location.reload();
                    }
                    else if( data == "error" ) {
                        dialog.modal('hide');
                        location.reload();
                    }
                    else if( data.substring(0, 26) == '<div class="modal-header">' ){
                        $('#modal_dialog').html( data );
                        $( '#modal_dialog_cancel' ).bind( 'click', function(){
                            dialog.modal('hide');
                        });
                    }
                    else {
                        dialog.modal('hide');
                        ossAddMessage( 'An unexpected error has occured.', 'error' );
                    }
                },
                error: ossAjaxErrorHandler
            });
        });
    });
</script>
