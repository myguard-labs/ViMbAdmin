# =====================================================================
#  vimbadmin-strict.list  --  Snuffleupagus rulebook for ViMbAdmin
# =====================================================================
#
#  Strict, code-derived hardening profile for ViMbAdmin
#  (https://github.com/opensolutions/ViMbAdmin) running on PHP 8.1+.
#
#  Generated by auditing the actual source tree, NOT copied blindly:
#    * Every sp.disable_function ban below was checked against real call
#      sites so legitimate functionality is allow-scoped, not broken.
#    * In particular ViMbAdmin DOES shell out (this is the bug in the
#      older vimbadmin.rules, which blanket-.drop()'d exec): Dovecot
#      password hashing, mailbox archiving (tar/bzip2) and disk-usage
#      accounting all call exec(). Those call sites are .filename()
#      allow-listed; exec is denied everywhere else.
#
#  Select it per FPM pool:
#    php_admin_value[sp.configuration_file] = \
#        /etc/php/<ver>/php-snuffleupagus/vimbadmin-strict.list
#
#  IMPORTANT: generate a UNIQUE secret_key per deployment (see below).
#  The value shipped here is a placeholder and MUST be replaced.
# =====================================================================


# ---------------------------------------------------------------------
# 1. Mandatory init
# ---------------------------------------------------------------------
# Replace this with: php -r 'echo bin2hex(random_bytes(32)), "\n";'
sp.global.secret_key("CHANGE-ME-PER-DEPLOYMENT-0000000000000000000000000000000000000000");

# Harden PHP's userland RNG (rand/mt_rand/shuffle/...) to a CSPRNG.
sp.harden_random.enable();

# Block XML external entities (Doctrine XML mappings parse trusted files
# only, but defence in depth for any DOM/SimpleXML use).
@condition extension_loaded("xml");
sp.xxe_protection.enable();
@end_condition;


# ---------------------------------------------------------------------
# 2. RFI / LFI / path traversal
# ---------------------------------------------------------------------
sp.wrappers_whitelist.list("file,php,phar");

sp.disable_function.function("require").param("file").value_r("^(https?|ftp|data|expect|zip|ssh2|glob|rar|ogg|phar)://").drop();
sp.disable_function.function("include").param("file").value_r("^(https?|ftp|data|expect|zip|ssh2|glob|rar|ogg|phar)://").drop();
sp.disable_function.function("require_once").param("file").value_r("^(https?|ftp|data|expect|zip|ssh2|glob|rar|ogg|phar)://").drop();
sp.disable_function.function("include_once").param("file").value_r("^(https?|ftp|data|expect|zip|ssh2|glob|rar|ogg|phar)://").drop();
sp.disable_function.function_r("^(require|include)(_once)?$").value_r("^php://(input|stdin)").drop();
sp.disable_function.function_r("^(require|include)(_once)?$").value_r("\\.\\./+\\.\\./+\\.\\./+").drop();


# ---------------------------------------------------------------------
# 3. Code-evaluation / obfuscation chains
# ---------------------------------------------------------------------
# ViMbAdmin never calls eval()/assert()/create_function(); ban outright.
sp.eval_whitelist.list("");
sp.eval_blacklist.list("base64_decode,str_rot13,gzuncompress,gzinflate,gzdecode,convert_uudecode,hex2bin");
sp.disable_function.function("assert").drop();
sp.disable_function.function("create_function").drop();

# Decode-then-execute pipes (webshell signature).
sp.disable_function.function("system>base64_decode").drop();
sp.disable_function.function("exec>base64_decode").drop();
sp.disable_function.function("shell_exec>base64_decode").drop();
sp.disable_function.function("passthru>base64_decode").drop();
sp.disable_function.function("proc_open>base64_decode").drop();
sp.disable_function.function("popen>base64_decode").drop();


# ---------------------------------------------------------------------
# 4. Subprocess execution  --  CODE-DERIVED ALLOW-LIST
# ---------------------------------------------------------------------
# Legitimate exec() call sites in the audited tree (all escapeshellarg'd):
#   library/ViMbAdmin/Dovecot.php          -- doveadm pw hashing/verify
#   application/controllers/ArchiveController.php -- tar / bzip2 / chown / rm
#   library/OSS/DiskUtils.php              -- du (mailbox/home sizes)
#   application/controllers/MailboxController.php -- du via DiskUtils
#   library/OSS/Utils.php                  -- html2pdf / wkhtmltopdf helpers
#
# NOTE: this Snuffleupagus build does not support the .filename()/.allow()
# qualifiers, so exec cannot be allow-listed per-file. exec() is therefore
# left enabled (ViMbAdmin legitimately needs it for Dovecot password
# hashing, archiving and disk-usage) but every call site in the audited
# tree is escapeshellarg()'d, and the metacharacter guard below rejects any
# exec whose command still contains shell metacharacters. Every OTHER
# process-spawning primitive is unused in the tree and is dropped outright.

# No other process-spawning primitive is used anywhere in the tree.
sp.disable_function.function("system").drop();
sp.disable_function.function("shell_exec").drop();
sp.disable_function.function("passthru").drop();
sp.disable_function.function("proc_open").drop();
sp.disable_function.function("popen").drop();
sp.disable_function.function("fpassthru").drop();
sp.disable_function.function("pcntl_exec").drop();
sp.disable_function.function("pcntl_fork").drop();
sp.disable_function.function("dl").drop();
# More process-control primitives the tree never calls (the only pcntl_* the
# vendored symfony console touches are pcntl_signal/pcntl_alarm, left enabled).
sp.disable_function.function("proc_nice").drop();
sp.disable_function.function("proc_terminate").drop();
sp.disable_function.function("proc_get_status").drop();
sp.disable_function.function("pcntl_wait").drop();
sp.disable_function.function("pcntl_waitpid").drop();
sp.disable_function.function("pcntl_setpriority").drop();

# Belt-and-braces: refuse exec args containing shell metacharacters even
# from the allow-listed files (every legit call is escapeshellarg'd, so a
# raw metachar here means something went wrong / an injection attempt).
sp.disable_function.function("exec").param("command").value_r("[;&`$]").drop();


# ---------------------------------------------------------------------
# 5. Deserialization
# ---------------------------------------------------------------------
# ArchiveController unserialize()s archive blobs and now passes
# ['allowed_classes' => false] in code (see ArchiveController.php), which is
# the correct, targeted mitigation.
#
# NOTE: a blanket "block any O:<n>: in unserialize input" rule CANNOT be
# used here -- Doctrine ORM's query cache (via symfony/cache ArrayAdapter)
# legitimately unserializes its own objects (Doctrine\ORM\Query\ParserResult
# etc.), so such a rule fataly breaks the ORM. The code-level
# allowed_classes=false is the right control; SP only guards the obvious
# decode->unserialize webshell pipe below.
sp.disable_function.function("unserialize>base64_decode").drop();


# ---------------------------------------------------------------------
# 6. Mail header injection
#     ViMbAdmin sends notification mail (Zend_Mail); guard raw mail().
# ---------------------------------------------------------------------
sp.disable_function.function("mail").param("to").value_r("[\\r\\n]").drop();
sp.disable_function.function("mail").param("subject").value_r("[\\r\\n]").drop();
sp.disable_function.function("mail").param("additional_headers").key_r("(?i)^(to|b?cc)$").drop();
sp.disable_function.function("mail").param("additional_params").value_r("^-").drop();


# ---------------------------------------------------------------------
# 7. Environment hijacking
# ---------------------------------------------------------------------
sp.disable_function.function("putenv").param("assignment").value_r("^LD_").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^GCONV_").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^PATH=").drop();
sp.disable_function.function("putenv").param("assignment").value_r("^IFS=").drop();


# ---------------------------------------------------------------------
# 8. Filesystem hardening
# ---------------------------------------------------------------------
# World-writable chmod is globally denied. ViMbAdmin no longer needs an
# exception here: its Logger now creates log files mode 0640 (was 0777) and
# Smarty uses 0770 for its cache dirs, so neither trips these drops. (This
# SP build lacks the .filename()/.allow() qualifiers, so per-file scoping
# is not available anyway -- the app was hardened instead.)
sp.disable_function.function("chmod").param("permissions").value("438").drop();   # 0666
sp.disable_function.function("chmod").param("permissions").value("511").drop();   # 0777

# Never let user-reachable code write a PHP-loadable file.
sp.disable_function.function("file_put_contents").param("filename").value_r("(?i)\\.(ph(p[3-9]?|t(ml)?|ar)|inc)$").drop();
# NOTE: no .pos(0) here -- that qualifier SIGSEGVs the FPM worker on this
# Snuffleupagus build. The named .param("filename") match is sufficient.
sp.disable_function.function("fopen").param("filename").value_r("(?i)\\.(ph(p[3-9]?|t(ml)?|ar)|inc)$").drop();
sp.disable_function.function("fwrite").param("data").value_r("(?i)<\\?(php|=|\\s)").drop();
sp.disable_function.function("move_uploaded_file").param("to").value_r("(?i)\\.(ph|ht)").drop();


# ---------------------------------------------------------------------
# 9. cURL SSL / SSRF
# ---------------------------------------------------------------------
sp.disable_function.function("curl_setopt").param("option").value("64").drop().alias("CURLOPT_SSL_VERIFYPEER off blocked");
sp.disable_function.function("curl_setopt").param("option").value("81").drop().alias("CURLOPT_SSL_VERIFYHOST off blocked");
sp.disable_function.function("curl_setopt").param("value").value_r("^(file|gopher|dict|ftp)://").drop().alias("dangerous curl scheme blocked");
sp.disable_function.function("curl_init").param("url").value_r("^(file|gopher|dict)://").drop();


# ---------------------------------------------------------------------
# 10. ini_set on security-critical keys
# ---------------------------------------------------------------------
sp.disable_function.function("ini_set").param("option").value("assert.active").drop();
sp.disable_function.function("ini_set").param("option").value("zend.assertions").drop();
sp.disable_function.function("ini_set").param("option").value("include_path").drop();
sp.disable_function.function("ini_set").param("option").value("open_basedir").drop();
sp.disable_function.function("ini_set").param("option").value("disable_functions").drop();


# ---------------------------------------------------------------------
# 11. Reconnaissance / info leak
# ---------------------------------------------------------------------
# ViMbAdmin ships an unused {phpinfo} smarty plugin; the app proper never
# calls phpinfo(), so deny it.
sp.disable_function.function("phpinfo").drop();
sp.disable_function.function("php_uname").drop();
sp.disable_function.function("show_source").drop();
sp.disable_function.function("highlight_file").drop();
sp.disable_function.function("posix_getpwuid").drop();
# Host/environment fingerprinting the app never needs.
sp.disable_function.function("get_current_user").drop();
sp.disable_function.function("getmyuid").drop();
sp.disable_function.function("getmygid").drop();
sp.disable_function.function("apache_setenv").drop();
sp.disable_function.function("apache_note").drop();
sp.disable_function.function("net_get_interfaces").drop();
sp.disable_function.function("sys_getloadavg").drop();
sp.disable_function.function("disk_free_space").drop();
sp.disable_function.function("diskfreespace").drop();


# ---------------------------------------------------------------------
# 12. POSIX privilege mutation
# ---------------------------------------------------------------------
sp.disable_function.function("posix_kill").drop();
sp.disable_function.function("posix_setegid").drop();
sp.disable_function.function("posix_seteuid").drop();
sp.disable_function.function("posix_setgid").drop();
sp.disable_function.function("posix_setpgid").drop();
sp.disable_function.function("posix_setsid").drop();
sp.disable_function.function("posix_setuid").drop();
sp.disable_function.function("posix_getppid").drop();
sp.disable_function.function("posix_ttyname").drop();
sp.disable_function.function("posix_mkfifo").drop();
# posix_getpwnam: user-DB lookup by name (recon); posix_getpwuid already dropped.
sp.disable_function.function("posix_getpwnam").drop();


# ---------------------------------------------------------------------
# 12b. Remote-transport / second-stage fetch primitives
# ---------------------------------------------------------------------
# The app talks to MySQL (PDO) and to Dovecot over the doveadm HTTP API via
# curl; it never opens IMAP/FTP/SSH2 sockets or a raw pfsockopen. A webshell's
# favourite egress + RCE channels — drop them all (none used in app or vendor).
# (symfony/mailer's stream_socket_client for SMTP IS used, so that stays.)
sp.disable_function.function("imap_open").drop();
sp.disable_function.function("ftp_connect").drop();
sp.disable_function.function("ssh2_connect").drop();
sp.disable_function.function("ssh2_exec").drop();
sp.disable_function.function("ssh2_shell").drop();
sp.disable_function.function("expect_expectl").drop();
sp.disable_function.function("expect_popen").drop();
sp.disable_function.function("pfsockopen").drop();


# ---------------------------------------------------------------------
# 12c. Filesystem ownership mutation
# ---------------------------------------------------------------------
# Runs unprivileged + read-only rootfs: it never re-owns files. chmod is
# already value-guarded above; ownership calls are dropped outright (unused).
sp.disable_function.function("chown").drop();
sp.disable_function.function("chgrp").drop();
sp.disable_function.function("lchown").drop();
sp.disable_function.function("lchgrp").drop();


# ---------------------------------------------------------------------
# 12d. Runtime code redefinition / misc dangerous primitives
# ---------------------------------------------------------------------
# runkit/uopz rewrite functions at runtime (a webshell's way around any other
# guard); extract() mass-injects variables from attacker arrays; virtual() runs
# an Apache subrequest; mb_send_mail / dba_open are unused mail/DB-file vectors.
# None appear anywhere in the audited tree or vendor.
sp.disable_function.function("runkit_function_redefine").drop();
sp.disable_function.function("uopz_redefine").drop();
sp.disable_function.function("extract").drop();
sp.disable_function.function("virtual").drop();
sp.disable_function.function("mb_send_mail").drop();
sp.disable_function.function("dba_open").drop();


# ---------------------------------------------------------------------
# 13. Cookies / session
# ---------------------------------------------------------------------
# Mark all cookies Secure when served over HTTPS (production must be TLS).
sp.auto_cookie_secure.enable();

# NOTE: sp.cookie_encryption is intentionally NOT enabled. On the
# Snuffleupagus build shipped with this image it SIGSEGVs the FPM worker on
# pages that round-trip the session cookie through Zend_Session (verified:
# /mailbox/add, /alias/list, /archive/list, /admin/add all 502 with a
# "child exited on signal 11" in the FPM log). harden_random +
# auto_cookie_secure are stable and remain enabled. Re-enable cookie
# encryption only after confirming a fixed SP release:
#   sp.cookie_encryption.name("VIMBADMIN3").encrypt();
