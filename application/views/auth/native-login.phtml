{tmplinclude file="header.phtml"}

<div class="page-content" >

    <div class="page-header" >
        <h1>Login to ViMbAdmin</h1>
    </div>

{OSS_Message}

{if isset( $demoAccount ) and $demoAccount}
<div class="alert alert-info">
    <strong>Demo instance.</strong> Log in with:
    <br/>Account: <code>{$demoAccount|escape}</code>
    {if isset( $demoPassword ) and $demoPassword}<br/>Password: <code>{$demoPassword|escape}</code>{/if}
    <br/><small class="muted">This account cannot change its password or 2FA.</small>
</div>
{/if}

<div class="row">

    <div class="span6 offset3">

    	<img src="{genUrl}/images/logo_500x159.jpg" />

        <p>
        Welcome to <em>ViMbAdmin</em>, a web application for managing your virtual mailboxes, domains and aliases.
        </p>

        {$formHtml nofilter}


        <div class="well">

            <p>
                Are you a user (mailbox owner) looking to change your <br />
                password? If so, please click on this button:

                <a style="float: right;" class="btn btn-primary" href="{genUrl controller="auth" action="change-password"}">Mailbox Password Change</a>
            </p>

        </div>


    </div>
</div>

</div>

{tmplinclude file="footer.phtml"}
