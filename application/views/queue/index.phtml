{*
 * Mailbox-task queue — super-admin.
 * Lists queued/running/recent doveadm tasks, lets the admin run the queue now
 * (POST+CSRF) and cancel PENDING tasks.
 *}
{tmplinclude file="header.phtml"}

<div class="page-content">

<div class="page-header">
    <h1>Mailbox task queue</h1>
</div>

<div class="row-fluid">
    <div class="span12">
        <div class="well">
            <p>
                Mailbox operations (repair/optimize, archive, delete) are queued
                here and processed by a background runner — up to a few at a time
                so a bulk action cannot overload Dovecot. The runner also fires
                from cron every few minutes; use the button below to drain it now.
            </p>
            <p>
                {foreach from=$counts key=st item=cnt}
                    <span class="label">{$st|escape}: {$cnt}</span>&nbsp;
                {foreachelse}
                    <em>Queue is empty.</em>
                {/foreach}
            </p>
            <form method="post" action="{genUrl controller='queue' action='run-now'}" style="display:inline">
                <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                <button class="btn btn-primary" type="submit">Run queue now</button>
            </form>
            <form method="post" action="{genUrl controller='queue' action='clear'}" style="display:inline"
                  onsubmit="return confirm('Delete all finished (done/failed/cancelled) tasks?');">
                <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                <button class="btn" type="submit">Clear finished</button>
            </form>
        </div>
    </div>
</div>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th style="color:#0b1220">#</th>
            <th style="color:#0b1220">Type</th>
            <th style="color:#0b1220">Mailbox</th>
            <th style="color:#0b1220">Initiated by</th>
            <th style="color:#0b1220">Status</th>
            <th style="color:#0b1220">Created</th>
            <th style="color:#0b1220">Finished</th>
            <th style="color:#0b1220">Action</th>
        </tr>
    </thead>
    <tbody>
    {foreach from=$tasks item=task}
        <tr>
            <td>{$task->getId()}</td>
            <td>{$task->getTypeLabel()|escape}</td>
            <td>{$task->getUsername()|escape}</td>
            <td>{if $task->getRequestedBy()}{$task->getRequestedBy()->getUsername()|escape}{else}&mdash;{/if}</td>
            <td>
                {if $task->getStatus() eq 'FAILED'}<span class="label label-important">{$task->getStatusLabel()|escape}</span>
                {elseif $task->getStatus() eq 'DONE'}<span class="label label-success">{$task->getStatusLabel()|escape}</span>
                {elseif $task->getStatus() eq 'RUNNING'}<span class="label label-info">{$task->getStatusLabel()|escape}</span>
                {elseif $task->getStatus() eq 'CANCELLED'}<span class="label">{$task->getStatusLabel()|escape}</span>
                {else}<span class="label label-warning">{$task->getStatusLabel()|escape}</span>{/if}
            </td>
            <td>{if $task->getCreatedAt()}{$task->getCreatedAt()->format('Y-m-d H:i')}{/if}</td>
            <td>{if $task->getFinishedAt()}{$task->getFinishedAt()->format('Y-m-d H:i')}{/if}</td>
            <td>
                {if $task->getStatus() eq $cancellable}
                    <form method="post" action="{genUrl controller='queue' action='run-task'}" style="display:inline"
                          onsubmit="return confirm('Run task #{$task->getId()} now?');">
                        <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                        <input type="hidden" name="id" value="{$task->getId()}" />
                        <button class="btn btn-mini btn-primary" type="submit">Run now</button>
                    </form>
                    <form method="post" action="{genUrl controller='queue' action='cancel'}" style="display:inline"
                          onsubmit="return confirm('Cancel task #{$task->getId()}?');">
                        <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                        <input type="hidden" name="id" value="{$task->getId()}" />
                        <button class="btn btn-mini btn-warning" type="submit">Cancel</button>
                    </form>
                {/if}
                {if $task->getStatus() eq 'FAILED'}
                    <form method="post" action="{genUrl controller='queue' action='retry'}" style="display:inline"
                          onsubmit="return confirm('Retry task #{$task->getId()}?');">
                        <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                        <input type="hidden" name="id" value="{$task->getId()}" />
                        <button class="btn btn-mini btn-success" type="submit">Retry</button>
                    </form>
                {/if}
                {if $task->getStatus() neq 'RUNNING'}
                    <form method="post" action="{genUrl controller='queue' action='delete'}" style="display:inline"
                          onsubmit="return confirm('Delete task #{$task->getId()}?');">
                        <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                        <input type="hidden" name="id" value="{$task->getId()}" />
                        <button class="btn btn-mini btn-danger" type="submit">Delete</button>
                    </form>
                {/if}
                {if $task->getLog()}
                    <a class="btn btn-mini" data-toggle="collapse" href="#log{$task->getId()}">Log</a>
                    <div id="log{$task->getId()}" class="collapse">
                        <pre style="margin-top:6px;max-height:14em;overflow:auto;">{$task->getLog()|escape}</pre>
                    </div>
                {/if}
            </td>
        </tr>
    {foreachelse}
        <tr><td colspan="8"><em>No tasks.</em></td></tr>
    {/foreach}
    </tbody>
</table>

</div>
{tmplinclude file="footer.phtml"}
