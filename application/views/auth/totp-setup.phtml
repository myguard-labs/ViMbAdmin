{tmplinclude file="header.phtml"}

<div class="page-content">

    <div class="page-header">
        <h1>Set Up Two-Factor Authentication</h1>
    </div>

{OSS_Message}

<div class="row">
    <div class="span6 offset3">

{if isset( $justEnabled ) && $justEnabled}
    <div class="alert alert-success">
        <strong>Two-factor is now enabled.</strong> Save these one-time backup
        codes somewhere safe &mdash; they're shown only now.
    </div>
    <pre>{foreach $backupCodes as $bc}{$bc|escape}
{/foreach}</pre>
    <a class="btn btn-primary" href="{genUrl}">Continue</a>
{else}
  <div style="text-align:center;">
    <p>Your administrator requires two-factor authentication on this account.
       Scan the QR code with an authenticator app (Aegis, Google Authenticator,
       1Password, &hellip;) and enter the 6-digit code to finish. You can't
       continue until 2FA is set up.</p>

    <p style="margin:1.5em 0;">
        <img src="{$qrDataUri|escape}" alt="TOTP QR code" />
    </p>

    <p>Can't scan? Enter this secret manually: <code>{$secret|escape}</code></p>

    {* No CSRF field: this step runs pre-auth (identity cleared) and is gated
       by the unforgeable pending-session id, so there's no token to embed. *}
    <form method="post" action="{genUrl controller='auth' action='totp-setup'}" class="form-inline" style="display:inline-block;">
        <input type="text" name="code" placeholder="6-digit code" autocomplete="one-time-code"
               inputmode="numeric" autofocus="autofocus" />
        <button type="submit" class="btn btn-primary">Enable &amp; continue</button>
    </form>
  </div>
{/if}

    </div>
</div>

</div>

{tmplinclude file="footer.phtml"}
