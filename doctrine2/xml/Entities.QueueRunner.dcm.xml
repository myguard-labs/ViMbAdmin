<?xml version="1.0"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="Entities\QueueRunner" table="queue_runner">
    <id name="id" type="bigint">
      <generator strategy="AUTO"/>
    </id>
    <field name="host" type="string" length="255" nullable="false"/>
    <field name="pid" type="integer" nullable="false"/>
    <field name="started_at" type="datetime" nullable="false"/>
    <field name="heartbeat_at" type="datetime" nullable="false"/>
    <indexes>
      <index name="queue_runner_heartbeat_idx" columns="heartbeat_at"/>
    </indexes>
  </entity>
</doctrine-mapping>
