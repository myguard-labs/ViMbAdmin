<?xml version="1.0"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="Entities\McpToken" repository-class="Repositories\McpToken" table="mcp_token">
    <id name="id" type="integer">
      <generator strategy="AUTO"/>
    </id>
    <field name="name" type="string" length="255" nullable="false"/>
    <field name="token_hash" type="string" length="64" nullable="false" unique="true"/>
    <field name="scope" type="string" length="255" nullable="false"/>
    <field name="allowed_ips" type="text" nullable="true"/>
    <field name="allowed_domains" type="text" nullable="true"/>
    <field name="created" type="datetime" nullable="false"/>
    <field name="expires_at" type="datetime" nullable="true"/>
    <field name="last_used_at" type="datetime" nullable="true"/>
    <field name="revoked" type="boolean" nullable="false"/>
    <indexes>
      <index name="mcp_token_hash_idx" columns="token_hash"/>
    </indexes>
  </entity>
</doctrine-mapping>
