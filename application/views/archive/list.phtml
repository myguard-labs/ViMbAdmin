{tmplinclude file="header.phtml"}

{if isset( $session->domain ) && $session->domain }
    {assign var=domain value=$session->domain}
{/if}

<div class="page-content" >

    <div class="page-header" >
        <h1>
            Archives {if isset( $domain ) && $domain}<small> for {$domain->getDomain()} {if $domain->getMaxMailboxes() != 0}({$domain->getMailboxCount()}/{$domain->getMaxMailboxes()}){/if}</small>
                <a class="btn have-tooltip-below" id="show_all_archives" title="Show All" href="{genUrl controller='archive' action='list' unset=1}">
                    <i class="icon-remove-circle"></i>
                </a>
            {/if}
        </h1>
    </div>

{OSS_Message}

<table id="list_table" cellpadding="0" cellspacing="0" border="0" class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Username</th>
            <th>Status</th>
            <th>Domain</th>
            <th>Size</th>
            <th>Archived</th>
            <th>User exists</th>
            <th>Autoprune</th>
            <th width="180"></th>
        </tr>
    </thead>
    <tbody>
{foreach $archives as $archive}
        <tr>
            <td>{$archive.username}</td>
            <td>{$statuses[$archive.status]}</td>
            <td>{$archive.domain}</td>
            <td>{if $archive.maildir_size}{$archive.maildir_size|filesize}{else}&mdash;{/if}</td>
            <td>{if $archive.archived_at}{$archive.archived_at->format('Y-m-d H:i')}{else}&mdash;{/if}</td>
            <td>{if $archive.user_exists}<span class="label label-success">Yes</span>{else}<span class="label">No</span>{/if}</td>
            <td>{if $archive.autoprune}<span class="label label-warning">On</span>{else}<span class="label">Off</span>{/if}</td>
            <td>
                <div class="btn-group">
                    {if $archive.status|in_array:$allowRestore}
                        <a class="btn btn-mini have-tooltip" id="restore-archive-{$archive.id}" title="Restore mail back into the mailbox" href="{genUrl controller='archive' action='restore' arid=$archive.id csrf=$csrfToken}"
                           onclick="return confirm('Restore {$archive.username|escape}? Recreates the mailbox if it was deleted, syncs the backed-up mail back, then removes the backup.');">
                            <i class="icon-retweet"></i>
                        </a>
                    {/if}
                    {if $archive.status|in_array:$allowDelete}
                        <a class="btn btn-mini btn-danger have-tooltip" id="delete-archive-{$archive.id}" title="Delete backup permanently" href="{genUrl controller='archive' action='delete' arid=$archive.id csrf=$csrfToken}"
                           onclick="return confirm('Permanently delete the backup for {$archive.username|escape}? This removes the /backups maildir and cannot be undone.');">
                            <i class="icon-trash"></i>
                        </a>
                    {/if}
                    {if $archive.autoprune}
                        <a class="btn btn-mini have-tooltip" id="autoprune-archive-{$archive.id}" title="Disable autoprune" href="{genUrl controller='archive' action='toggle-autoprune' arid=$archive.id csrf=$csrfToken}"
                           onclick="return confirm('Disable autoprune for {$archive.username|escape}? Its backup will no longer expire automatically.');">
                            <i class="icon-off"></i>
                        </a>
                    {else}
                        <a class="btn btn-mini btn-warning have-tooltip" id="autoprune-archive-{$archive.id}" title="Enable autoprune (resets archived date to now)" href="{genUrl controller='archive' action='toggle-autoprune' arid=$archive.id csrf=$csrfToken}"
                           onclick="return confirm('Enable autoprune for {$archive.username|escape}? This resets its archived date to now, so the prune window restarts.');">
                            <i class="icon-time"></i>
                        </a>
                    {/if}
                </div>
            </td>
        </tr>
{/foreach}
    </tbody>
</table>

<br />
<br />

<script type="text/javascript">{tmplinclude file='archive/js/list.js'}</script>

</div>

{tmplinclude file="footer.phtml"}
