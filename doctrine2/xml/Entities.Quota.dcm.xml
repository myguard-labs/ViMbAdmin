<?xml version="1.0"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xsi="http://www.w3.org/2001/XMLSchema-instance" schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
  <entity name="Entities\Quota" table="dovecot_quota" read-only="true">
    <id name="username" type="string" length="255">
      <generator strategy="NONE"/>
    </id>
    <field name="bytes" type="bigint" nullable="false">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <field name="messages" type="bigint" nullable="false">
      <options>
        <option name="default">0</option>
      </options>
    </field>
    <field name="updated_at" type="datetime" nullable="false" column-definition="timestamp NOT NULL DEFAULT current_timestamp() ON UPDATE current_timestamp()"/>
  </entity>
</doctrine-mapping>
