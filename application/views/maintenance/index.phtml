{*
 * Maintenance — super-admin housekeeping.
 * Two POST+CSRF forms: disable inactive-domain accounts, and Doctrine schema sync.
 *}
{tmplinclude file="header.phtml"}

<div class="page-content">

<div class="page-header">
    <h1>Maintenance</h1>
</div>

{OSS_Message}

{* ============================ Version, build & updates ============================ *}
<div class="row-fluid">
    <div class="span6">
        <div class="well">
            <h3>Version &amp; build</h3>
            <p>
                Release: <strong>{$appVersion|escape}</strong>
                <form method="post" style="display:inline;margin-left:.5em;"
                      action="{genUrl controller='maintenance' action='check-update'}">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <input type="hidden" name="which" value="release" />
                    <button class="btn btn-small" type="submit">Check for newer release</button>
                </form>
            </p>
            <p>
                Git commit:
                {if $gitCommit}
                    <strong><code>{$gitCommitShort|escape}</code></strong>
                    <a class="muted" target="_blank" rel="noopener"
                       href="https://github.com/{$githubRepo|escape}/commit/{$gitCommit|escape}">view</a>
                {else}
                    <span class="muted">unknown (no build marker)</span>
                {/if}
                <form method="post" style="display:inline;margin-left:.5em;"
                      action="{genUrl controller='maintenance' action='check-update'}">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <input type="hidden" name="which" value="commit" />
                    <button class="btn btn-small" type="submit">Check for newer commit</button>
                </form>
            </p>
            <p><small class="muted">Update checks query GitHub
                (<code>{$githubRepo|escape}</code>). A newer commit means a newer
                build is available — rebuild the image to update.</small></p>
        </div>
    </div>

    {* ============================ Background runs ============================ *}
    <div class="span6">
        <div class="well">
            <h3>Background runs</h3>
            <p>
                Last queue runner started:
                {if $lastQueueRun}
                    <strong>{$lastQueueRun|escape}</strong>
                {else}
                    <span class="muted">never (since this was added)</span>
                {/if}
            </p>
            <p>
                Last prune run:
                {if $lastPrune}
                    <strong>{$lastPrune|escape}</strong>
                {else}
                    <span class="muted">never (since this was added)</span>
                {/if}
            </p>
            <p><small class="muted">The queue is drained only by the external
                cron (<code>queue.cli-run</code>) / the remote trigger endpoint;
                opening this tab no longer nudges it. Pruning is manual (the
                buttons below).</small></p>
        </div>
    </div>
</div>

<div class="row-fluid">

    {* ============================ Disable inactive accounts ============================ *}
    <div class="span6">
        <div class="well">
            <h3>Disable inactive-domain accounts</h3>
            <p>
                Set <strong>active = 0</strong> on every mailbox and alias whose
                parent domain is itself inactive. Already-disabled rows are left
                untouched, so this is safe to run repeatedly.
            </p>
            <p>
                Currently affected:
                <strong>{$stats.domains}</strong> inactive domain(s),
                <strong>{$stats.mailboxes}</strong> still-active mailbox(es),
                <strong>{$stats.aliases}</strong> still-active alias(es).
            </p>

            {if $stats.mailboxes + $stats.aliases > 0}
                <form method="post" action="{genUrl controller='maintenance' action='disable-inactive'}"
                      onsubmit="return confirm('Disable {$stats.mailboxes} mailbox(es) and {$stats.aliases} alias(es) of inactive domains?');">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <button class="btn btn-warning" type="submit">
                        Disable {$stats.mailboxes} mailbox(es) + {$stats.aliases} alias(es)
                    </button>
                </form>
            {else}
                <p class="text-success"><em>Nothing to disable — all clear.</em></p>
            {/if}
        </div>
    </div>

    {* ================================ Schema update ================================ *}
    <div class="span6">
        <div class="well">
            <h3>Update database schema</h3>
            <p>
                Sync the database to the current Doctrine mappings. This shows
                the pending SQL first — nothing is applied until you confirm.
            </p>
            <p>
                Application version: <strong>{$appVersion|escape}</strong>
                {if $appDbVersionName}<br/><small class="muted">Schema: {$appDbVersionName|escape}</small>{/if}
            </p>
            <p>
                Schema version:
                <strong>{if $dbVersionApplied !== null}{$dbVersionApplied}{else}—{/if}</strong>
                applied / <strong>{if $dbVersionCode !== null}{$dbVersionCode}{else}—{/if}</strong> expected by code.
                {if $dbPending > 0}
                    <span class="label label-warning">{$dbPending} pending statement(s)</span>
                {else}
                    <span class="label label-success">up to date</span>
                {/if}
                <br/>
                <small class="muted">Schema is applied automatically on container start; this button is a manual fallback.</small>
            </p>

            {if isset( $schemaSql )}
                <div class="alert alert-warning">
                    <strong>Review before applying.</strong>
                    {$schemaSql|@count} statement(s) will run:
                </div>
                <pre style="max-height:18em;overflow:auto;">{foreach from=$schemaSql item=stmt}{$stmt|escape};
{/foreach}</pre>
                <form method="post" action="{genUrl controller='maintenance' action='schema-update'}"
                      onsubmit="return confirm('Apply {$schemaSql|@count} schema statement(s) to the live database?');">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <input type="hidden" name="confirm" value="1" />
                    <button class="btn btn-danger" type="submit">Apply {$schemaSql|@count} statement(s)</button>
                    <a class="btn" href="{genUrl controller='maintenance' action='index'}">Cancel</a>
                </form>
            {else}
                <form method="post" action="{genUrl controller='maintenance' action='schema-update'}">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <button class="btn btn-primary" type="submit">Show pending schema changes</button>
                </form>
            {/if}
        </div>
    </div>

</div>

<div class="row-fluid">
    {* ============================ Flush Dovecot auth cache ============================ *}
    <div class="span6">
        <div class="well">
            <h3>Flush Dovecot auth cache</h3>
            <p>
                Clear Dovecot's authentication cache so the next login re-reads
                the userdb/passdb. Use after bulk password or active-flag changes
                that aren't picking up immediately. Non-destructive.
            </p>
            <form method="post" action="{genUrl controller='maintenance' action='flush-auth-cache'}">
                <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                <button class="btn btn-primary" type="submit">Flush auth cache</button>
            </form>
        </div>
    </div>

    {* ============================ Recalc quota for all mailboxes ============================ *}
    <div class="span6">
        <div class="well">
            <h3>Recalculate quota usage (all mailboxes)</h3>
            <p>
                Queue a Dovecot <strong>quota recalc</strong> for every active
                mailbox ({$activeMailboxCount} mailbox(es)), refreshing the
                <code>Used</code> figures shown in the mailbox/domain lists.
                Lighter than a full repair — quota only. Processed gradually by
                the background runner.
            </p>
            {if isset( $confirmRecalcAll )}
                <form method="post" action="{genUrl controller='maintenance' action='recalc-all'}"
                      onsubmit="return confirm('Queue quota recalc for ALL {$activeMailboxCount} active mailboxes?');">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <input type="hidden" name="confirm" value="1" />
                    <button class="btn btn-warning" type="submit">Yes, queue {$activeMailboxCount} recalc task(s)</button>
                    <a class="btn" href="{genUrl controller='maintenance' action='index'}">Cancel</a>
                </form>
            {else}
                <form method="post" action="{genUrl controller='maintenance' action='recalc-all'}">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <button class="btn btn-primary" type="submit">Recalc quota for all mailboxes…</button>
                </form>
            {/if}
        </div>
    </div>
</div>

<div class="row-fluid">
    {* ======================= Repair & optimize ALL mailboxes ======================= *}
    <div class="span12">
        <div class="well">
            <h3>Repair &amp; optimize all mailboxes</h3>
            <div class="alert alert-error">
                <strong>Heavy operation.</strong> This queues a repair/optimize
                job (force-resync + index + purge + quota recalc) for
                <strong>every active mailbox</strong>
                ({$activeMailboxCount} mailbox(es)). On a large server this is a
                lot of Dovecot work — run it <em>only if absolutely necessary</em>
                (e.g. after index corruption or a storage migration). The jobs are
                queued and processed gradually in the background, not all at once.
            </div>

            {if isset( $confirmRepairAll )}
                <form method="post" action="{genUrl controller='maintenance' action='repair-all'}"
                      onsubmit="return confirm('Queue repair/optimize for ALL {$activeMailboxCount} active mailboxes?');">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <input type="hidden" name="confirm" value="1" />
                    <button class="btn btn-danger" type="submit">
                        Yes, queue {$activeMailboxCount} repair task(s)
                    </button>
                    <a class="btn" href="{genUrl controller='maintenance' action='index'}">Cancel</a>
                </form>
            {else}
                <form method="post" action="{genUrl controller='maintenance' action='repair-all'}">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <button class="btn btn-warning" type="submit">Repair &amp; optimize all mailboxes…</button>
                </form>
            {/if}
        </div>
    </div>
</div>

<div class="row-fluid">
    {* ======================= Autoprune archive backups ======================= *}
    <div class="span12">
        <div class="well">
            <h3>Autoprune archive backups</h3>
            <div class="alert alert-info">
                Deleted-mailbox backups are flagged <strong>autoprune</strong> and
                removed automatically once they pass the
                <code>queue.autoprune.days</code> window
                ({if isset($pruneExpiredDays)}{$pruneExpiredDays}{else}90{/if} days).
                Pruning deletes the on-disk <code>/backups</code> maildir
                (<code>doveadm fs delete</code>) <em>and</em> the archive row.
                Explicit archives are never autopruned.
            </div>

            {if isset( $confirmPruneExpired )}
                <form method="post" action="{genUrl controller='maintenance' action='prune-expired'}"
                      onsubmit="return confirm('Prune {$pruneExpiredCount} expired archive backup(s)? This permanently deletes their mail backups.');">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <input type="hidden" name="confirm" value="1" />
                    <button class="btn btn-danger" type="submit">Yes, prune {$pruneExpiredCount} expired backup(s)</button>
                    <a class="btn" href="{genUrl controller='maintenance' action='index'}">Cancel</a>
                </form>
            {elseif isset( $confirmPruneAll )}
                <form method="post" action="{genUrl controller='maintenance' action='prune-all'}"
                      onsubmit="return confirm('Delete ALL {$pruneAllCount} autoprune-on archive backup(s) regardless of age? This cannot be undone.');">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <input type="hidden" name="confirm" value="1" />
                    <button class="btn btn-danger" type="submit">Yes, delete all {$pruneAllCount} autoprune backup(s)</button>
                    <a class="btn" href="{genUrl controller='maintenance' action='index'}">Cancel</a>
                </form>
            {else}
                <form method="post" action="{genUrl controller='maintenance' action='prune-expired'}" style="display:inline">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <button class="btn btn-warning" type="submit">Run autoprune now (expired only)…</button>
                </form>
                <form method="post" action="{genUrl controller='maintenance' action='prune-all'}" style="display:inline">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <button class="btn btn-danger" type="submit">Delete ALL autoprune backups…</button>
                </form>
            {/if}
        </div>
    </div>
</div>

{* ============================ Unmanaged (orphan) maildirs ============================ *}
<div class="row-fluid">
    <div class="span12">
        <div class="well">
            <h3>Unmanaged maildirs</h3>
            <p>
                Scan the mail store for <strong>orphan maildirs</strong> — mail
                on disk that has <strong>no ViMbAdmin mailbox</strong> (e.g. an
                account deleted in the panel but its mail left behind).
                Importing one runs a background task: it briefly creates a
                temporary user so Dovecot can read the maildir, repairs it, then
                — if it still holds mail — backs it up to the archive (kept, not
                auto-pruned) and removes the source; if it is just an empty
                leftover skeleton, it is removed without a backup.
            </p>

            {if isset( $orphans )}
                {if $orphans|@count > 0}
                    <div class="alert alert-warning">
                        Found <strong>{$orphans|@count}</strong> unmanaged maildir(s).
                    </div>
                    <table class="table table-striped table-bordered">
                        <thead><tr><th>Maildir</th><th width="120"></th></tr></thead>
                        <tbody>
                        {foreach from=$orphans item=o}
                            <tr>
                                <td>{$o|escape}</td>
                                <td>
                                    <form method="post" action="{genUrl controller='maintenance' action='backup-orphans'}"
                                          onsubmit="return confirm('Import {$o|escape}? Mail is backed up then the source maildir is removed (empty leftovers are just removed).');">
                                        <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                                        <input type="hidden" name="username" value="{$o|escape}" />
                                        <button class="btn btn-mini btn-primary" type="submit">Import</button>
                                    </form>
                                </td>
                            </tr>
                        {/foreach}
                        </tbody>
                    </table>

                    {if isset( $confirmBackupOrphans ) and $confirmBackupOrphans}
                        <form method="post" action="{genUrl controller='maintenance' action='backup-orphans'}" style="display:inline;">
                            <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                            <input type="hidden" name="confirm" value="1" />
                            <button class="btn btn-danger" type="submit">Queue import of all {$orphans|@count} maildir(s)</button>
                            <a class="btn" href="{genUrl controller='maintenance' action='index'}">Cancel</a>
                        </form>
                    {else}
                        <form method="post" action="{genUrl controller='maintenance' action='backup-orphans'}" style="display:inline;">
                            <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                            <button class="btn btn-primary" type="submit">Import all {$orphans|@count}</button>
                        </form>
                        <form method="post" action="{genUrl controller='maintenance' action='scan-orphans'}" style="display:inline;">
                            <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                            <button class="btn" type="submit">Re-scan</button>
                        </form>
                    {/if}
                {else}
                    <div class="alert alert-success">No orphan maildirs — every maildir on disk has a mailbox.</div>
                {/if}
            {else}
                <form method="post" action="{genUrl controller='maintenance' action='scan-orphans'}">
                    <input type="hidden" name="csrf" value="{$csrfToken|escape}" />
                    <button class="btn btn-primary" type="submit">Scan for unmanaged maildirs</button>
                </form>
            {/if}
        </div>
    </div>
</div>

</div>
{tmplinclude file="footer.phtml"}
